{
  "name": "batch-processor",
  "version": "1.0.0",
  "description": "Batch Processor - Media to Text Converter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "build:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.batch-processor.app",
    "productName": "Batch Processor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": null
    }
  }
}
